// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// === MODELOS DE BETTER AUTH ===
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  
  // Tus campos adicionales
  userName      String    @unique
  firstName     String?
  lastName      String?
  isActive      Boolean   @default(true)
  createdDate   DateTime  @default(now())

  sessions      Session[]
  accounts      Account[]
  verifications Verification[]
  miembrosConsejo MiembroConsejo[]

  @@map("users") // Opcional: mapear a nombre de tabla diferente
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                   String   @id @default(uuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  idToken              String?
  password             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  userId     String?
  
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verifications")
}




// === TUS MODELOS EXISTENTES JMV ===
model Actividades {
  id             Int          @id @default(autoincrement())
  id_publicacion Int
  id_centro      Int

  publicacion    Publicacion  @relation(fields: [id_publicacion], references: [id], onDelete: Cascade)
  centro         Centro       @relation(fields: [id_centro], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdDate    DateTime     @default(now())
  createdById    String?
  modifiedDate   DateTime?
  modifiedById   String?
  deletedDate    DateTime?
  deletedById    String?
}

model Biblioteca {
  id           Int       @id @default(autoincrement())
  ruta_doc     String?
  titulo       String?
  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Centro {
  id           Int            @id @default(autoincrement())
  nombre       String?
  direccion    String?
  estatusId    Int?
  estatus      Estatus?       @relation(fields: [estatusId], references: [id], onDelete: NoAction)
  publicaciones Publicacion[]
  actividades   Actividades[]
  usuarios      Usuarios[]
  comunidades   Comunidad[]
  vocales       Vocal[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Comunidad {
  id           Int         @id @default(autoincrement())
  nombre       String?
  integrantes  Int
  idEtapa      Int
  centroId     Int
  estatusId    Int
  centro       Centro      @relation(fields: [centroId], references: [id], onDelete: Cascade)
  estatus      Estatus     @relation(fields: [estatusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios     Usuarios[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Estatus {
  id           Int         @id @default(autoincrement())
  nombre       String?
  usuarios     Usuarios[]
  centros      Centro[]
  comunidades  Comunidad[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Publicacion {
  id           Int           @id @default(autoincrement())
  img          String?
  titulo       String?
  descripcion  String?
  fecha        DateTime
  id_centro    Int
  id_estado    Int
  centro       Centro        @relation(fields: [id_centro], references: [id], onDelete: NoAction)
  actividades  Actividades[]
  recordatorios Recordatorio[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Recordatorio {
  id           Int           @id @default(autoincrement())
  fecha        DateTime
  idPublicacion Int
  isPublicacion Boolean      @default(false)
  publicacion  Publicacion?  @relation(fields: [idPublicacion], references: [id], onDelete: Cascade)

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Tipo {
  id           Int         @id @default(autoincrement())
  nombre       String?
  vocalias     Vocalia[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Valor {
  id           Int          @id @default(autoincrement())
  nombre       String       @db.VarChar(100)
  vocalValores VocalValor[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Vocal {
  id           Int           @id @default(autoincrement())
  name         String?
  img          String?
  idCentro     Int
  idVocalia    Int

  centro       Centro        @relation(fields: [idCentro], references: [id], onDelete: Cascade)
  vocalia      Vocalia       @relation(fields: [idVocalia], references: [id], onDelete: NoAction)
  vocalValores VocalValor[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Vocalia {
  id           Int         @id @default(autoincrement())
  nombre       String?
  id_Tipovocalia Int
  tipo         Tipo        @relation(fields: [id_Tipovocalia], references: [id], onDelete: NoAction)
  usuarios     Usuarios[]
  vocales      Vocal[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model VocalValor {
  id        Int      @id @default(autoincrement())
  vocalId   Int
  valorId   Int
  vocal     Vocal    @relation(fields: [vocalId], references: [id], onDelete: Cascade)
  valor     Valor    @relation(fields: [valorId], references: [id], onDelete: Cascade)
}

model Usuarios {
  id           Int        @id @default(autoincrement())
  nombre       String?
  apellido     String?
  telefono     String?
  idComunidad  Int
  idCentro     Int
  idVocalia    Int
  idEstatus    Int

  comunidad    Comunidad  @relation(fields: [idComunidad], references: [id], onDelete: NoAction, onUpdate: NoAction)
  centro       Centro     @relation(fields: [idCentro], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vocalia      Vocalia    @relation(fields: [idVocalia], references: [id], onDelete: NoAction, onUpdate: NoAction)
  estatus      Estatus    @relation(fields: [idEstatus], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deletedDate  DateTime?
  deletedById  String?
}

model Testimonios {
  id           Int       @id @default(autoincrement())
  nombre       String?   @db.VarChar(50)    // Especificar longitud máxima
  mensaje      String?   @db.VarChar(250)   // Especificar longitud máxima de 250 caracteres
  reputacion   Int?
  iglesia      String?   @db.VarChar(200)   // Especificar longitud máxima de 200 caracteres

  createdDate  DateTime  @default(now())
  createdById  String?
  createdByIp  String?

  modifiedDate DateTime?
  modifiedById String?
  modifiedByIp String?

  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?
  deletedByIp  String?
}

model Formacion {
  id           Int       @id @default(autoincrement())
  titulo      String?
  descripcion String?    @db.Text
  modulo       ModulosFormacion?
  enlace      String?
  ruta        String?
  

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?
}

model ConsejoNacional {
  id           Int        @id @default(autoincrement())
  periodo      String     // "2024-2026"
  fechaInicio  DateTime
  fechaFin     DateTime?
  lema         String?
  fotoUrl      String?
  isActual     Boolean    @default(false)
  
  miembros     MiembroConsejo[]
  
  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("consejos_nacionales")
}

model MiembroConsejo {
  id           Int         @id @default(autoincrement())
  consejoId    Int
  userId       String?     // Referencia al usuario si existe en el sistema
  nombre       String
  cargo        CargoConsejo
  ciudad       String?
  fotoUrl      String?
  bioCorta     String?
  bioExtendida String?     @db.Text
  telefono     String?
  email        String?
  estado       EstadoMiembro @default(Titular)
  
  // Trayectoria (podría ser una relación separada si es compleja)
  trayectoria  Json?       // { anio: number, rol: string, lugar?: string }[]
  
  consejo      ConsejoNacional @relation(fields: [consejoId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("miembros_consejo")
}

enum CargoConsejo {
  CoordinadorNacional
  SecretarioNacional
  TesoreroNacional
  VocalDeFormacion
  VocalDeMisionYCaridad
  VocalLiturgiaYMariana
  VocalDeExpansion
  VocalDePrejuveniles
  VocalDeCulturaYRecreacion
}

enum EstadoMiembro {
  Titular
  Suplente
}

enum ModulosFormacion {
  Voluntario
  Catequesis
  Oraciones
  Podcast
  Mision
  Guia
}

model Evento {
  id                  Int       @id @default(autoincrement())
  slug                String    @unique
  titulo              String    @db.VarChar(200)
  descripcionBreve    String    @db.VarChar(300)
  descripcionCompleta String?   @db.Text
  imagenUrl           String
  ubicacion           String    @db.VarChar(200)
  fecha               DateTime
  hora                String    @db.VarChar(50)
  email               String?   @db.VarChar(150)
  telefono            String?   @db.VarChar(30)
  etiquetas           Json      // string[]
  actividades         Json      // string[]
  agenda              Json      // { dia: string, actividades: { hora: string, actividad: string }[] }[]
  requisitos          Json      // string[]

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("eventos")
}

model Noticia {
  id                  Int       @id @default(autoincrement())
  slug                String    @unique
  titulo              String    @db.VarChar(200)
  descripcionBreve    String    @db.VarChar(300)
  descripcionCompleta String?   @db.LongText
  imagenUrl           String    @db.VarChar(500)
  ubicacion           String    @db.VarChar(200)
  fecha               DateTime
  hora                String?   @db.VarChar(50)
  tipo                String    @db.VarChar(100)
  etiquetas           Json      // string[]
  destacada           Boolean   @default(false)

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("noticias")
}

model NoticiaTipo {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique @db.VarChar(100)
  activo      Boolean  @default(true)
  createdDate DateTime @default(now())

  @@map("noticia_tipos")
}

// === NUEVOS MODELOS JMV — CENTROS Y ACTIVIDADES ===

model CentroJmv {
  id                      Int      @id @default(autoincrement())
  slug                    String   @unique
  nombreParroquia         String   @db.VarChar(200)
  ubicacion               String   @db.VarChar(300)
  cantidadMiembrosActivos Int
  nombreCoordinadora      String   @db.VarChar(200)
  telefono                String   @db.VarChar(30)
  correo                  String   @db.VarChar(150)
  resumen                 String   @db.Text
  anioFundacion           Int
  imagenUrl               String   @db.VarChar(500)
  etiquetas               Json
  ultimaActividadId       Int?

  ultimaActividad         ActividadJmv?      @relation("UltimaActividadCentro", fields: [ultimaActividadId], references: [id], onDelete: SetNull)
  miembros                MiembroCentroJmv[]
  comunidades             ComunidadJmv[]
  actividades             ActividadJmv[]     @relation("ActividadesDeCentro")

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("centros_jmv")
}

model ActividadJmv {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  titulo    String   @db.VarChar(200)
  centroId  Int
  resumen   String   @db.Text
  fecha     DateTime
  imagenUrl String   @db.VarChar(500)
  etiquetas Json

  centro        CentroJmv   @relation("ActividadesDeCentro", fields: [centroId], references: [id], onDelete: Cascade)
  centrosUltAct CentroJmv[] @relation("UltimaActividadCentro")

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("actividades_jmv")
}

model MiembroCentroJmv {
  id          Int    @id @default(autoincrement())
  centroId    Int
  nombre      String @db.VarChar(200)
  imagenUrl   String @db.VarChar(500)
  descripcion String @db.Text
  cargo       String @db.VarChar(100)

  centro CentroJmv @relation(fields: [centroId], references: [id], onDelete: Cascade)

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("miembros_centro_jmv")
}

model ComunidadJmv {
  id               Int      @id @default(autoincrement())
  centroId         Int
  nombre           String   @db.VarChar(200)
  imagenUrl        String   @db.VarChar(500)
  cantidadMiembros Int
  inicioDate       DateTime
  etapa            String   @db.VarChar(100)
  etiquetas        Json

  centro CentroJmv @relation(fields: [centroId], references: [id], onDelete: Cascade)

  createdDate  DateTime  @default(now())
  createdById  String?
  modifiedDate DateTime?
  modifiedById String?
  deleted      Boolean   @default(false)
  deletedDate  DateTime?
  deletedById  String?

  @@map("comunidades_jmv")
}

model CargoCentroJmv {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique @db.VarChar(100)
  activo      Boolean  @default(true)
  createdDate DateTime @default(now())

  @@map("cargos_centro_jmv")
}

model EtapaComunidadJmv {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique @db.VarChar(100)
  activo      Boolean  @default(true)
  createdDate DateTime @default(now())

  @@map("etapas_comunidad_jmv")
}