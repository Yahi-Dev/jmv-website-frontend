# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# uploaded media (generated at runtime, not source)
/public/formacion
/public/consejos
/public/miembros

# next.js
/.next/
/out/
/build

# debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# unused package-manager lockfile (project uses npm)
/pnpm-lock.yaml

# editor / OS junk
.DS_Store
Thumbs.db
*.swp
*~

# agent / spec tooling (not part of the app)
.agent
.agents
.claude
.kiro
skills-lock.json
